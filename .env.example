# ============================================================
#  LeadFlow AI — configuration
# ============================================================
#  Don't edit this file directly. Run the setup wizard instead:
#      npm run setup
#  It will ask you a few questions and generate your .env
# ============================================================

# --- Apify: lead scraping -----------------------------------
# Free account + token: https://console.apify.com/settings/integrations
APIFY_TOKEN=

# Actors used (change only if you prefer different ones)
GOOGLE_MAPS_ACTOR=compass/crawler-google-places
APOLLO_ACTOR=code_crafter/apollo-io-scraper

# --- Groq: AI personalization -------------------------------
# Free API key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Gmail: sending -----------------------------------------
# GMAIL_APP_PASSWORD must be a Google App Password (16 chars),
# NOT your normal password. Requires 2-Step Verification ON.
# Create one: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Set true only if antivirus/proxy breaks the SMTP TLS handshake
SMTP_TLS_INSECURE=false

# --- Sending behaviour --------------------------------------
# Delay between each email, in seconds (default 3–4 minutes).
# Keep this generous — it protects your sender reputation.
MIN_GAP_SECONDS=180
MAX_GAP_SECONDS=240

# --- Local server -------------------------------------------
PORT=3000

